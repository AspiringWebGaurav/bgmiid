# BGMI Name Stylist - Environment Variables Template
# Copy this file to a new file named '.env' and fill in the values.
# NEVER commit the actual '.env' file containing secrets to version control!

# Anything.com Project Token (for deployment/hosting integrations)
ANYTHING_PROJECT_TOKEN="your_project_token_here"

# Firebase Service Account Credentials (JSON string)
# Example: '{"type":"service_account","project_id":"bgmiidservices",...}'
FIREBASE_SERVICE_ACCOUNT='your_firebase_service_account_json_here'
