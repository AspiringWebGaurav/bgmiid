# BGMI Name Stylist - Environment Variables Template
# Copy this file to a new file named '.env' and fill in the values.
# NEVER commit the actual '.env' file containing secrets to version control!

# Anything.com Project Token (for deployment/hosting integrations)
ANYTHING_PROJECT_TOKEN="your_project_token_here"

# Firebase Service Account Credentials (JSON string)
# Example: '{"type":"service_account","project_id":"bgmiidservices",...}'
FIREBASE_SERVICE_ACCOUNT='your_firebase_service_account_json_here'

# Firebase Client Configuration (Public API Key and project identifiers)
NEXT_PUBLIC_FIREBASE_API_KEY="your_firebase_api_key_here"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your_project_id.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your_project_id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your_project_id.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your_messaging_sender_id_here"
NEXT_PUBLIC_FIREBASE_APP_ID="your_app_id_here"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="your_measurement_id_here"
